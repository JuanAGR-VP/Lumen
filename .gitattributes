# ==========================================================
#  .gitattributes para proyecto Unity (LUMEN)
#  - Normaliza saltos de linea
#  - Marca los archivos YAML de Unity como texto (mejor diff/merge)
#  - Git LFS al final, COMENTADO: actívalo cuando agregues
#    audio/musica/video. Antes de usarlo corre: git lfs install
# ==========================================================

* text=auto

# --- Archivos YAML de Unity (escenas, prefabs, materiales, etc.) ---
*.unity         text
*.prefab        text
*.asset         text
*.mat           text
*.anim          text
*.controller    text
*.physicsMaterial2D text
*.meta          text

# --- Git LFS (OPCIONAL) ---
# Descomenta estas lineas y corre "git lfs install" cuando metas
# audio o video pesado. Para sprites PNG pequenos no hace falta.
